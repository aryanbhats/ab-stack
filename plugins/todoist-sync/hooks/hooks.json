{
  "description": "Auto-triggers Todoist sync at session boundaries. Fires on SessionStart to show due tasks, and on Stop to offer task completion.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/dispatcher.py",
            "timeout": 5,
            "statusMessage": "Checking Todoist..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/dispatcher.py",
            "timeout": 5,
            "statusMessage": "Syncing Todoist..."
          }
        ]
      }
    ]
  }
}
